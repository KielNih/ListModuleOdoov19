<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_employee_document_tree" model="ir.ui.view">
        <field name="name">hr.employee.document.tree</field>
        <field name="model">hr.employee.document</field>
        <field name="arch" type="xml">
           <list string="Employee Documents" 
                  decoration-danger="is_expired" 
                  decoration-warning="is_expiring_soon">
                
                <field name="name"/>
                <field name="employee_id"/>
                <field name="expiry_date"/>
                
                <field name="is_expired" column_invisible="1"/>
                <field name="is_expiring_soon" column_invisible="1"/>
                
                <field name="is_expiry_notified" optional="hide"/>
        </list>
        </field>
    </record>

    <record id="view_hr_employee_document_form" model="ir.ui.view">
        <field name="name">hr.employee.document.form</field>
        <field name="model">hr.employee.document</field>
        <field name="arch" type="xml">
            <form string="Employee Document">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" placeholder="e.g. ID Card, Contract" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" />
                        </group>
                        <group>
                            <field name="expiry_date" />
                            <field name="is_expiry_notified" readonly="1" />
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_hr_employee_document" model="ir.actions.act_window">
        <field name="name">Employee Documents</field>
        <field name="res_model">hr.employee.document</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create the first document for an employee!
            </p>
        </field>
    </record>

    <menuitem id="menu_hr_employee_document"
        name="Documents"
        parent="hr.menu_hr_employee_payroll"
        action="action_hr_employee_document"
        sequence="20" />

</odoo>