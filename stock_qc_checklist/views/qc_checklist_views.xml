<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qc_checklist_form" model="ir.ui.view">
        <field name="name">qc.checklist.form</field>
        <field name="model">qc.checklist</field>
        <field name="arch" type="xml">
            <form string="QC Checklist">
                <header>
                    <button name="action_confirm_qc" type="object" string="Confirm QC" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="picking_id" readonly="1" force_save="1"/>
                        </group>
                        <group>
                            <field name="is_quantity_match" readonly="state == 'done'"/>
                            <field name="is_packaging_good" readonly="state == 'done'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" readonly="state == 'done'"/>
                        </page>
                    </notebook>
                </sheet>
                
                <chatter/>
                
            </form>
        </field>
    </record>

    <record id="view_qc_checklist_list" model="ir.ui.view">
        <field name="name">qc.checklist.list</field>
        <field name="model">qc.checklist</field>
        <field name="arch" type="xml">
            <list string="QC Checklists">
                <field name="name"/>
                <field name="picking_id"/>
                <field name="inspector_id"/>
                <field name="check_date"/>
                <field name="is_passed" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_qc_checklist" model="ir.actions.act_window">
        <field name="name">QC Checklists</field>
        <field name="res_model">qc.checklist</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_qc_checklist" 
              name="QC Checklists" 
              parent="stock.menu_stock_warehouse_mgmt" 
              action="action_qc_checklist" 
              sequence="15"/>
</odoo>