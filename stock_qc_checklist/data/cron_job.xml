<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_qc_checklist" model="ir.sequence">
            <field name="name">QC Checklist Sequence</field>
            <field name="code">qc.checklist.seq</field>
            <field name="prefix">QC/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="ir_cron_check_missing_qc" model="ir.cron">
            <field name="name">Inventory: Check Missing QC Checklist for Receipts</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_missing_qc()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>